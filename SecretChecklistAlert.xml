<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

	<!--
		SecretChecklistAlert.xml
		ContainedAlertFrame template for the "Secret Collected!" toast.

		Visual elements reused from Blizzard's AchievementToast atlas:
		  glow    – radiating flash behind the frame
		  shine   – animated shimmer sweeping left-to-right
		  Overlay – decorative circle ring around the icon

		Background and accent lines are created in Lua (OnLoad) using
		SetColorTexture, so no external image assets are required.
	-->

	<ContainedAlertFrame
		name="SecretChecklist_AlertFrame_Template"
		mixin="SecretChecklist_AlertFrameMixin"
		inherits="AlertFrameTemplate"
		parent="UIParent"
		hidden="true"
		frameStrata="DIALOG"
		virtual="true">

		<Size x="256" y="84"/>

		<!-- animIn  : AlertFrameTemplate's OnShow plays this automatically -->
		<!-- waitAndAnimOut : auto-started by OnShow; startDelay drives the display window -->
		<Animations>
			<AnimationGroup parentKey="animIn">
				<Alpha fromAlpha="1" toAlpha="0" duration="0"   order="1"/>
				<Alpha fromAlpha="0" toAlpha="1" duration="0.3" order="2"/>
			</AnimationGroup>
			<AnimationGroup parentKey="waitAndAnimOut">
				<Alpha startDelay="6" fromAlpha="1" toAlpha="0" duration="1.5" parentKey="animOut">
					<Scripts>
						<OnFinished>
							self:GetRegionParent():Hide();
						</OnFinished>
					</Scripts>
				</Alpha>
			</AnimationGroup>
		</Animations>

		<Layers>
			<!-- Background and accent lines are built in OnLoad (Lua) -->
			<Layer level="BACKGROUND">
				<!-- Header: "Secret Collected!" -->
				<FontString parentKey="Name" inherits="GameFontHighlight" maxLines="1" justifyV="TOP" justifyH="CENTER">
					<Anchors>
						<Anchor point="TOP"   x="0"   y="-14"/>
						<Anchor point="LEFT"  x="72"  y="0"/>
						<Anchor point="RIGHT" x="-10" y="0"/>
					</Anchors>
				</FontString>
				<!-- Body: secret name -->
				<FontString parentKey="Label" inherits="GameFontNormal" maxLines="2" justifyV="TOP" justifyH="CENTER">
					<Anchors>
						<Anchor point="TOP"   x="0"   y="-34"/>
						<Anchor point="LEFT"  x="72"  y="0"/>
						<Anchor point="RIGHT" x="-10" y="0"/>
					</Anchors>
				</FontString>
			</Layer>

			<!-- Glow and shine overlays from the achievement toast atlas -->
			<Layer level="OVERLAY">
				<Texture file="Interface\AchievementFrame\AchievementToast" alphaMode="ADD" hidden="true" parentKey="glow">
					<Size x="314" y="136"/>
					<Anchors>
						<Anchor point="CENTER" x="0" y="0"/>
					</Anchors>
					<TexCoords left="0.0009765625" right="0.3076171875" top="0.169921875" bottom="0.302734375"/>
					<Animations>
						<AnimationGroup parentKey="animIn">
							<Alpha fromAlpha="0" toAlpha="1" duration="0.2" order="1"/>
							<Alpha fromAlpha="1" toAlpha="0" duration="0.5" order="2"/>
							<Scripts>
								<OnFinished>
									self:GetParent():Hide();
								</OnFinished>
							</Scripts>
						</AnimationGroup>
					</Animations>
				</Texture>

				<Texture file="Interface\AchievementFrame\AchievementToast" alphaMode="ADD" hidden="true" parentKey="shine">
					<Size x="67" y="85"/>
					<Anchors>
						<Anchor point="TOPLEFT" x="0" y="0"/>
					</Anchors>
					<TexCoords left="0.9296875" right="0.9951171875" top="0.169921875" bottom="0.2529296875"/>
					<Animations>
						<AnimationGroup parentKey="animIn">
							<Alpha       fromAlpha="0" toAlpha="1" duration="0.2" order="1"/>
							<Translation offsetX="210" offsetY="0" duration="0.85" order="2"/>
							<Alpha       startDelay="0.35" fromAlpha="1" toAlpha="0" duration="0.5" order="2"/>
							<Scripts>
								<OnFinished>
									self:GetParent():Hide();
								</OnFinished>
							</Scripts>
						</AnimationGroup>
					</Animations>
				</Texture>
			</Layer>
		</Layers>

		<!-- Icon: secret icon texture + decorative ring overlay -->
		<Frames>
			<Frame parentKey="Icon">
				<Size x="64" y="64"/>
				<Anchors>
					<Anchor point="LEFT" x="4" y="0"/>
				</Anchors>
				<Layers>
					<Layer level="ARTWORK">
						<Texture parentKey="Texture">
							<Size x="46" y="46"/>
							<Anchors>
								<Anchor point="CENTER" x="0" y="0"/>
							</Anchors>
							<TexCoords left="0.07" right="0.93" top="0.07" bottom="0.93"/>
						</Texture>
					</Layer>
					<Layer level="OVERLAY">
						<!-- Decorative ring from the achievement toast atlas -->
						<Texture parentKey="Overlay" file="Interface\AchievementFrame\AchievementToast">
							<Size x="74" y="74"/>
							<Anchors>
								<Anchor point="CENTER" x="-1" y="2"/>
							</Anchors>
							<TexCoords left="0.107421875" right="0.1796875" top="0.505859375" bottom="0.578125"/>
						</Texture>
					</Layer>
				</Layers>
			</Frame>
		</Frames>

		<Scripts>
			<OnLoad method="OnLoad"/>
			<OnEnter inherit="append" method="OnEnter"/>
			<OnLeave inherit="append" method="OnLeave"/>
			<OnClick method="OnClick"/>
		</Scripts>
	</ContainedAlertFrame>

</Ui>
